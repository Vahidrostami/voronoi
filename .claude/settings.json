{
  "permissions": {
    "allow": [
      "bash:bd *",
      "bash:git *",
      "bash:tmux *",
      "bash:./scripts/*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
