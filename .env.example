# ============================================================
# Voronoi — Environment Configuration
# Copy this to .env and fill in your values.
# Environment variables override ~/.voronoi/config.json settings.
# ============================================================

# -----------------------------------------------------------
# GitHub / Copilot auth — used for publishing, cloning, and agent auth
# -----------------------------------------------------------
# Dedicated Copilot CLI token for unattended/headless server runs.
# Recommended: fine-grained PAT with the "Copilot Requests" permission.
# This takes precedence over GH_TOKEN/GITHUB_TOKEN and avoids overriding a
# separate gh CLI login.
# COPILOT_GITHUB_TOKEN=

# GitHub token for gh CLI / publishing. Copilot CLI will also read this if
# COPILOT_GITHUB_TOKEN is unset, so use a token that works for both workflows
# or leave it empty and authenticate gh separately with `gh auth login`.
# Note: classic PATs are not supported by current Copilot CLI auth.
GH_TOKEN=

# Optional fallback token recognized by Copilot CLI if the two variables above
# are unset.
# GITHUB_TOKEN=

# Optional GitHub hostname for GitHub Enterprise Cloud with data residency.
# GH_HOST=github.com

# Optional Copilot CLI state directory. Useful on long-running servers so
# tmux restarts and human-gate resumes reuse the same Copilot session state.
# COPILOT_HOME=$HOME/.copilot

# GitHub org where investigation results are published
# VORONOI_GITHUB_LAB_ORG=voronoi-lab
# VORONOI_GITHUB_VISIBILITY=private
# VORONOI_GITHUB_AUTO_PUBLISH=true

# -----------------------------------------------------------
# Telegram — required for Telegram-first workflow
# -----------------------------------------------------------
# Bot token from @BotFather on Telegram
VORONOI_TG_BOT_TOKEN=
# Comma-separated list of allowed Telegram user IDs or usernames.
# Leave blank to allow all users (open access).
# Example: 112423044,vahidrostami,jane_doe
VORONOI_TG_USER_ALLOWLIST=
# Comma-separated list of user IDs/usernames allowed to run /voronoi ops.
# Defaults to VORONOI_TG_USER_ALLOWLIST if not set.
# VORONOI_TG_OPS_USERS=
# Default chat ID for outbound notifications (when running from CLI).
# Auto-detected when users interact via Telegram — only needed if you
# run demos from the terminal before ever texting the bot.
# VORONOI_TG_CHAT_ID=
# Comma-separated event filter (empty = all events)
# Events: swarm_start, wave_dispatch, merge, quality_gate_fail,
#         convergence, swarm_complete, agent_timeout, agent_retry,
#         swarm_abort, inbox_command
# VORONOI_TG_EVENTS=

# Optional: MVCHA gateway (route through MVCHA instead of direct Telegram API)
# VORONOI_TG_MVCHA_URL=http://localhost:3000
# VORONOI_TG_MVCHA_SECRET=
# VORONOI_TG_PREFER_MVCHA=false

# -----------------------------------------------------------
# Agent CLI — which AI agent to use
# -----------------------------------------------------------
# Which agent CLI to dispatch workers with: copilot | claude
# VORONOI_AGENT_COMMAND=copilot
# Flags passed to the agent CLI
# VORONOI_AGENT_FLAGS=--allow-all
# Model for the orchestrator agent (e.g. claude-opus-4.6, gpt-5.4)
# Empty = use CLI default. See `copilot --help` for available models.
# VORONOI_ORCHESTRATOR_MODEL=
# Model for worker/subagents (e.g. claude-sonnet-4.6, claude-haiku-4.5)
# Using a faster/cheaper model for workers can reduce cost significantly.
# VORONOI_WORKER_MODEL=

# -----------------------------------------------------------
# Server Mode (~/.voronoi/) — for persistent server deployments
# -----------------------------------------------------------
# Log verbosity: DEBUG | INFO (default) | WARNING | ERROR
# VORONOI_LOG_LEVEL=INFO
# Max investigations running simultaneously
# VORONOI_MAX_CONCURRENT=2
# Max parallel agents per investigation
# VORONOI_MAX_AGENTS=4
# Days to keep completed investigation workspaces
# VORONOI_WORKSPACE_RETENTION_DAYS=30

# -----------------------------------------------------------
# Docker Sandbox — isolates agent code execution
# -----------------------------------------------------------
# VORONOI_SANDBOX_ENABLED=true
# VORONOI_SANDBOX_IMAGE=voronoi-python:latest
# VORONOI_SANDBOX_CPUS=4
# VORONOI_SANDBOX_MEMORY=8g
# VORONOI_SANDBOX_TIMEOUT_HOURS=12
# VORONOI_SANDBOX_NETWORK=true
# VORONOI_SANDBOX_FALLBACK_TO_HOST=true
