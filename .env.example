# Voronoi — Telegram Integration
# Copy this to .env and fill in your values
VORONOI_TG_BOT_TOKEN=           # From @BotFather
VORONOI_TG_CHAT_ID=             # Your Telegram chat ID (DM or group)

# Optional: MVCHA gateway (if you want to route through MVCHA instead of direct API)
# VORONOI_TG_MVCHA_URL=http://localhost:3000
# VORONOI_TG_MVCHA_SECRET=
# VORONOI_TG_PREFER_MVCHA=false
