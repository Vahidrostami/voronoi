# ============================================================
# Voronoi — Environment Configuration
# Copy this to .env and fill in your values.
# Environment variables override ~/.voronoi/config.json settings.
# ============================================================

# -----------------------------------------------------------
# GitHub — required for cloning repos and publishing results
# -----------------------------------------------------------
# Personal Access Token (PAT) — scopes: repo, read:org, workflow
# Create at: https://github.com/settings/tokens
# Alternative: run `gh auth login` which sets this automatically
GH_TOKEN=

# GitHub org where investigation results are published
# VORONOI_GITHUB_LAB_ORG=voronoi-lab
# VORONOI_GITHUB_VISIBILITY=private
# VORONOI_GITHUB_AUTO_PUBLISH=true

# -----------------------------------------------------------
# Telegram — required for Telegram-first workflow
# -----------------------------------------------------------
# Bot token from @BotFather on Telegram
VORONOI_TG_BOT_TOKEN=
# Chat ID to restrict bot to (DM or group). Leave blank to allow all chats.
VORONOI_TG_CHAT_ID=
# Comma-separated event filter (empty = all events)
# Events: swarm_start, wave_dispatch, merge, quality_gate_fail,
#         convergence, swarm_complete, agent_timeout, agent_retry,
#         swarm_abort, inbox_command
# VORONOI_TG_EVENTS=

# Optional: MVCHA gateway (route through MVCHA instead of direct Telegram API)
# VORONOI_TG_MVCHA_URL=http://localhost:3000
# VORONOI_TG_MVCHA_SECRET=
# VORONOI_TG_PREFER_MVCHA=false

# -----------------------------------------------------------
# Agent CLI — which AI agent to use
# -----------------------------------------------------------
# Which agent CLI to dispatch workers with: copilot | claude
# VORONOI_AGENT_COMMAND=copilot
# Flags passed to the agent CLI
# VORONOI_AGENT_FLAGS=--allow-all

# -----------------------------------------------------------
# Server Mode (~/.voronoi/) — for persistent server deployments
# -----------------------------------------------------------
# Max investigations running simultaneously
# VORONOI_MAX_CONCURRENT=2
# Max parallel agents per investigation
# VORONOI_MAX_AGENTS=4
# Days to keep completed investigation workspaces
# VORONOI_WORKSPACE_RETENTION_DAYS=30

# -----------------------------------------------------------
# Docker Sandbox — isolates agent code execution
# -----------------------------------------------------------
# VORONOI_SANDBOX_ENABLED=true
# VORONOI_SANDBOX_IMAGE=voronoi-python:latest
# VORONOI_SANDBOX_CPUS=4
# VORONOI_SANDBOX_MEMORY=8g
# VORONOI_SANDBOX_TIMEOUT_HOURS=12
# VORONOI_SANDBOX_NETWORK=true
# VORONOI_SANDBOX_FALLBACK_TO_HOST=true
